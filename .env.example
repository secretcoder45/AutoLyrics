# =============================================================
#  AutoLyrics — Environment Variables
# =============================================================

# ---- General ----
AUTOLYRICS_RUN_NAME=default
AUTOLYRICS_LOG_LEVEL=INFO
AUTOLYRICS_DEVICE=auto                # auto | cpu | cuda | mps
AUTOLYRICS_DATA_DIR=./data
AUTOLYRICS_CACHE_DIR=./.cache/autolyrics
AUTOLYRICS_OUTPUT_DIR=./runs

# ---- Datasets ----
DALI_ROOT=./data/raw/dali
JAMENDO_ROOT=./data/raw/jamendo
# NUS-48E is expected under AUTOLYRICS_DATA_DIR/raw/nus48e

# ---- Hugging Face ----
HF_HOME=~/.cache/huggingface
HF_TOKEN=                             # Required for gated models / private datasets
HUGGINGFACE_HUB_TOKEN=

# ---- MLflow ----
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=autolyrics

# ---- Weights & Biases (optional) ----
WANDB_API_KEY=
WANDB_PROJECT=autolyrics
WANDB_DISABLED=true

# ---- API ----
AUTOLYRICS_API_DEFAULT_MODEL=openai/whisper-small
AUTOLYRICS_API_FINETUNED_CHECKPOINT=
AUTOLYRICS_API_HOST=0.0.0.0
AUTOLYRICS_API_PORT=8000

# ---- Gradio Demo ----
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
